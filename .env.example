# === Autonomous Blog Agent — Environment Variables ===

# OpenAI (required for LLM)
OPENAI_API_KEY=your_key_here

# Tavily (required for web research)
TAVILY_API_KEY=your_key_here

# Google Gemini (optional — used for image generation)
GOOGLE_API_KEY=your_key_here

# LLM model override (optional, defaults to gpt-4o-mini)
# LLM_MODEL=gpt-4o-mini

# Publishing (optional)
DEVTO_API_KEY=your_devto_api_key
HASHNODE_TOKEN=your_hashnode_token
HASHNODE_PUBLICATION_ID=your_publication_id
